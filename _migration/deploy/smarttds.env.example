# SmartTds API environment — copy to  /www/wwwroot/smarttds-api/smarttds.env
# then:  chmod 600 /www/wwwroot/smarttds-api/smarttds.env
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5080
# database (PostgreSQL on this same VPS)
Db__Host=127.0.0.1
Db__Port=5432
Db__Username=smarttds_app
Db__Password=CHANGE_ME_app_password
Db__MasterDatabase=masterdbtds
Db__YearDatabaseTemplate=smarttds{0}
# JWT signing secret — MUST be long & random (>=32 chars). Generate with:
#   openssl rand -base64 48
Jwt__Key=CHANGE_ME_long_random_64_char_secret
Jwt__Issuer=SmartTdsApi
Jwt__Audience=SmartTdsClient
Jwt__ExpiryMinutes=480

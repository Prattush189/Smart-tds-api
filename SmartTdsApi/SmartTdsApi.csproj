<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- API release version. The lightweight "API patch" updater (desktop
         ApiUpdater) compares this (read from the installed SmartTdsApi.dll
         FileVersion) against the remote api-version.json manifest. BUMP THIS
         on every API release that you intend to ship as a patch. -->
    <Version>1.1.11</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- unit tests cover internal helpers (Api, NormalizeYear) -->
    <InternalsVisibleTo Include="SmartTdsApi.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.27" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
    <PackageReference Include="Npgsql" Version="8.0.5" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

</Project>
